<%
const fmt = (n) => n != null ? parseFloat(n).toLocaleString('es-SV', { minimumFractionDigits: 2, maximumFractionDigits: 2 }) : '0.00';
const TYPE_ICON = { Visita: '📍', Llamada: '📞', WhatsApp: '💬', Mensaje: '✉️' };
const STATUS_CLASS = { pendiente: 'badge-warning', autorizado: 'badge-success', rechazado: 'badge-error', aplicado: 'badge-success' };
%>
<%- include('../partials/head') %>
  <%- include('../partials/sidebar', { user, currentPath: '/dashboard' }) %>

  <div class="main-content">
    <%- include('../partials/topbar', { title }) %>

    <div class="page-body">

      <!-- KPIs del gestor -->
      <div class="stats-grid">
        <div class="stat-card">
          <div class="stat-label">Gestiones hoy</div>
          <div class="stat-value"><%= todayStats.total || 0 %></div>
          <div class="stat-sub"><%= todayStats.withPayment || 0 %> con pago reportado</div>
        </div>
        <div class="stat-card">
          <div class="stat-label">Recaudado hoy</div>
          <div class="stat-value amber">$ <%- fmt(todayStats.totalAmount) %></div>
          <div class="stat-sub">USD</div>
        </div>
        <div class="stat-card">
          <div class="stat-label">Clientes asignados</div>
          <div class="stat-value navy"><%= assignedClients.total || 0 %></div>
          <div class="stat-sub">
            <% if ((assignedClients.critical || 0) > 0) { %>
              <span style="color:var(--error)"><%= assignedClients.critical %> críticos (>90d)</span>
            <% } else { %>
              $ <%- fmt(assignedClients.totalDeuda) %> deuda total
            <% } %>
          </div>
        </div>
        <div class="stat-card">
          <div class="stat-label">Tareas pendientes</div>
          <div class="stat-value <%= (pendingTasks.vencidas || 0) > 0 ? 'amber' : '' %>"><%= pendingTasks.total || 0 %></div>
          <div class="stat-sub">
            <% if ((pendingTasks.vencidas || 0) > 0) { %>
              <span style="color:var(--error)"><%= pendingTasks.vencidas %> vencida<%= pendingTasks.vencidas > 1 ? 's' : '' %></span>
            <% } else { %>
              al día
            <% } %>
          </div>
        </div>
      </div>

      <!-- Accesos rápidos -->
      <div style="display:flex;gap:12px;margin-bottom:24px;flex-wrap:wrap">
        <a href="/clients" class="btn btn-primary">Ver mis clientes</a>
        <a href="/tasks" class="btn btn-ghost">Ver tareas</a>
      </div>

      <!-- Últimas gestiones -->
      <div class="card">
        <div class="card-header">
          <span class="card-title">Mis últimas gestiones</span>
        </div>
        <% if (recentGestiones.length === 0) { %>
        <div class="empty-state" style="padding:40px">
          <div class="empty-state-icon">📋</div>
          <div class="empty-state-title">Sin gestiones aún</div>
          <div class="empty-state-desc">Tus gestiones registradas aparecerán aquí</div>
        </div>
        <% } else { %>
        <div class="table-wrap">
          <table>
            <thead>
              <tr>
                <th>Fecha</th>
                <th>Cliente</th>
                <th>Tipo</th>
                <th>Estado</th>
                <th style="text-align:right">Monto</th>
              </tr>
            </thead>
            <tbody>
              <% recentGestiones.forEach(g => { %>
              <tr>
                <td class="text-muted" style="font-size:11px;white-space:nowrap"><%= g.fecha %></td>
                <td>
                  <a href="/clients/<%= g.clientId %>" style="color:inherit;text-decoration:none;font-weight:500"><%= g.clientName %></a>
                  <span class="risk-chip <%= g.riskCategory %>" style="margin-left:6px"><%= g.riskCategory %></span>
                </td>
                <td><%= TYPE_ICON[g.type] || '' %> <%= g.type %></td>
                <td><span class="badge <%= STATUS_CLASS[g.status] || '' %>"><%= g.status %></span></td>
                <td style="text-align:right" class="mono">
                  <% if (g.paymentAmount) { %>
                    <span class="amber">$ <%- fmt(g.paymentAmount) %></span>
                  <% } else { %>
                    <span class="text-muted">—</span>
                  <% } %>
                </td>
              </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
        <% } %>
      </div>

    </div>
  </div>
<%- include('../partials/foot') %>
