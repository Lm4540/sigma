<%
const ROLES_MAP = { 1: 'Administrador', 2: 'Supervisor', 3: 'Gestor', 4: 'Secretaria', 5: 'Jefe de Operaciones' };
const currentPath = locals.currentPath || '';
const userRoleId = user ? user.roleId : 0;
const PERMS = {
  1: ['view_dashboard','view_clients','authorize_payment','import_data','manage_users','manage_branches','manage_assignments','view_audit_logs','view_reports','manage_tasks','export_reports','manage_legal'],
  2: ['view_dashboard','view_clients','create_collection','authorize_payment','manage_assignments','view_reports','manage_tasks','export_reports','manage_legal'],
  3: ['view_dashboard','view_clients','create_collection','manage_tasks'],
  4: ['view_authorized_payments','update_payment_status'],
  5: ['view_dashboard','view_clients','review_payment','view_reports','export_reports','manage_tasks'],
};
const hasPerm = (p) => (PERMS[userRoleId] || []).includes(p);
%>
<nav class="sidebar">
  <div class="sidebar-brand">
    <div class="brand-mark">
      <img class="brand-icon" src="/icons/icon-96.png" alt="SIGMA Logo">
      <div>
        <div class="brand-name">SIGMA</div>
        <div class="brand-sub">Cobranza Móvil</div>
      </div>
    </div>
  </div>

  <div class="sidebar-nav">
    <% if (hasPerm('view_dashboard')) { %>
    <a href="/dashboard" class="nav-link <%= currentPath === '/dashboard' ? 'active' : '' %>">
      <svg class="icon" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="1" y="1" width="6" height="6" rx="1"/><rect x="9" y="1" width="6" height="6" rx="1"/><rect x="1" y="9" width="6" height="6" rx="1"/><rect x="9" y="9" width="6" height="6" rx="1"/></svg>
      Dashboard
    </a>
    <% } %>

    <% if (hasPerm('view_clients')) { %>
    <div class="nav-section">Cartera</div>
    <a href="/clients" class="nav-link <%= currentPath.startsWith('/clients') ? 'active' : '' %>">
      <svg class="icon" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="8" cy="5" r="3"/><path d="M2 14c0-3.3 2.7-6 6-6s6 2.7 6 6"/></svg>
      Clientes
    </a>
    <a href="/collections/list" class="nav-link <%= currentPath.startsWith('/collections/list') ? 'active' : '' %>">
      <svg class="icon" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="2" y="2" width="12" height="12" rx="1.5"/><path d="M5 6h6M5 10h6"/></svg>
      Gestiones
    </a>
    <% } %>

    <% if (hasPerm('manage_assignments')) { %>
    <a href="/assignments" class="nav-link <%= currentPath.startsWith('/assignments') ? 'active' : '' %>">
      <svg class="icon" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M2 4h12M2 8h8M2 12h5"/></svg>
      Asignaciones
    </a>
    <% } %>

    <% if (hasPerm('review_payment') || hasPerm('authorize_payment') || hasPerm('update_payment_status')) { %>
    <div class="nav-section">Pagos</div>
    <% } %>

    <% if (hasPerm('review_payment')) { %>
    <a href="/collections/pending" class="nav-link <%= currentPath === '/collections/pending' ? 'active' : '' %>">
      <svg class="icon" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 2v12M8 4v8M4 6v4"/></svg>
      Revisión de Pagos
    </a>
    <% } %>

    <% if (hasPerm('authorize_payment')) { %>
    <a href="/collections/pending" class="nav-link <%= currentPath === '/collections/pending' ? 'active' : '' %>">
      <svg class="icon" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="8" cy="8" r="6"/><path d="M8 5v3l2 2"/></svg>
      Pagos Pendientes
    </a>
    <% } %>

    <% if (hasPerm('update_payment_status')) { %>
    <a href="/collections/pending" class="nav-link <%= currentPath === '/collections/pending' ? 'active' : '' %>">
      <svg class="icon" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M1 8l5 5 9-9"/></svg>
      Pagos por Aplicar
    </a>
    <% } %>

    <% if (hasPerm('manage_tasks')) { %>
    <div class="nav-section">Seguimiento</div>
    <a href="/tasks" class="nav-link <%= currentPath.startsWith('/tasks') ? 'active' : '' %>">
      <svg class="icon" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="2" y="2" width="12" height="12" rx="1.5"/><path d="M5 8l2 2 4-4"/></svg>
      Tareas
    </a>
    <% } %>

    <% if (hasPerm('view_reports')) { %>
    <div class="nav-section">Reportes</div>
    <a href="/reports" class="nav-link <%= currentPath.startsWith('/reports') ? 'active' : '' %>">
      <svg class="icon" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M3 12V8m4 4V5m4 7V3"/></svg>
      Reportes
    </a>
    <% } %>

    <% if (hasPerm('manage_legal')) { %>
    <div class="nav-section">Jurídico</div>
    <a href="/legal" class="nav-link <%= currentPath.startsWith('/legal') ? 'active' : '' %>">
      <svg class="icon" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M8 1L2 4v4c0 3.3 2.7 5.5 6 7 3.3-1.5 6-3.7 6-7V4L8 1z"/></svg>
      Procesos Legales
    </a>
    <% } %>

    <% if (hasPerm('manage_users') || hasPerm('manage_branches') || hasPerm('view_audit_logs')) { %>
    <div class="nav-section">Administración</div>
    <% } %>

    <% if (hasPerm('manage_users')) { %>
    <a href="/users" class="nav-link <%= currentPath.startsWith('/users') ? 'active' : '' %>">
      <svg class="icon" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="6" cy="5" r="2.5"/><path d="M1 13c0-2.8 2.2-5 5-5"/><circle cx="12" cy="10" r="2.5"/><path d="M9.5 12.5h5"/><path d="M12 10v5"/></svg>
      Usuarios
    </a>
    <% } %>

    <% if (hasPerm('manage_branches')) { %>
    <a href="/branches" class="nav-link <%= currentPath.startsWith('/branches') ? 'active' : '' %>">
      <svg class="icon" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M8 2l5 4v8H3V6z"/></svg>
      Sucursales
    </a>
    <% } %>

    <% if (hasPerm('view_audit_logs')) { %>
    <a href="/audit" class="nav-link <%= currentPath.startsWith('/audit') ? 'active' : '' %>">
      <svg class="icon" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M2 4h12v10H2z"/><path d="M5 4V2h6v2"/><path d="M5 8h6M5 11h4"/></svg>
      Auditoría
    </a>
    <% } %>

    <div class="nav-section">Mi Cuenta</div>
    <a href="/profile" class="nav-link <%= currentPath === '/profile' ? 'active' : '' %>">
      <svg class="icon" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="8" cy="8" r="3"/><path d="M3 14c0-2.5 2-4.5 5-4.5s5 2 5 4.5"/></svg>
      Mi Perfil
    </a>
  </div>

  <div class="sidebar-footer">
    <div class="user-chip-row">
      <div class="user-chip-info">
        <div class="user-avatar"><%= user ? user.name?.charAt(0).toUpperCase() : '?' %></div>
        <div class="user-info">
          <div class="user-name"><%= user ? user.name : '' %></div>
          <div class="user-role"><%= ROLES_MAP[userRoleId] || '' %></div>
        </div>
      </div>
    </div>
  </div>
</nav>
